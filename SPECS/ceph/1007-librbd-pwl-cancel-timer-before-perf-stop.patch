From 93caa1d8eaf065157d57568b027d644521975a42 Mon Sep 17 00:00:00 2001
From: Sun Yuechi <sunyuechi@iscas.ac.cn>
Date: Fri, 29 May 2026 16:35:26 +0800
Subject: [PATCH] librbd/cache/pwl: cancel periodic_stats timer before
 perf_stop()

AbstractWriteLog::shut_down() calls perf_stop(), which deletes
m_perfcounter, but the 5s periodic_stats timer is only canceled later
in the destructor. If it fires in between, periodic_stats ->
update_image_cache_state dereferences the freed m_perfcounter. Cancel
the timer under m_timer_lock first, mirroring the destructor.

Signed-off-by: Sun Yuechi <sunyuechi@iscas.ac.cn>
---
 src/librbd/cache/pwl/AbstractWriteLog.cc | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/src/librbd/cache/pwl/AbstractWriteLog.cc b/src/librbd/cache/pwl/AbstractWriteLog.cc
index e407d1a5d..e37ed7f75 100644
--- a/src/librbd/cache/pwl/AbstractWriteLog.cc
+++ b/src/librbd/cache/pwl/AbstractWriteLog.cc
@@ -649,6 +649,11 @@ void AbstractWriteLog<I>::shut_down(Context *on_finish) {

   Context *ctx = new LambdaContext(
     [this, on_finish](int r) {
+      {
+        std::lock_guard timer_locker(*m_timer_lock);
+        m_timer->cancel_event(m_timer_ctx);
+        m_timer_ctx = nullptr;
+      }
       if (m_perfcounter) {
         perf_stop();
       }
