From 68184ff0f9a2f9c13df45652b9d12d8af52b3f9f Mon Sep 17 00:00:00 2001
From: HNO3Miracle <xiangao.or@isrc.iscas.ac.cn>
Date: Thu, 11 Jun 2026 20:04:38 +0800
Subject: [PATCH] Do not parse test flags in init

context_test.go registers a custom -save test flag in init(), then immediately parses flags. In a Go test binary, that happens too early: Go's own test flags, such as -test.testlogfile, have not been registered yet, so the test binary fails before running tests:

  flag provided but not defined: -test.testlogfile

After removing flag.Parse(), TestPushPop deterministically produces hash 31e908ee1c2ea180da98fd5681a89d05 in the OBS test environment, so update the expected hash accordingly.
---
 context_test.go | 3 +--
 1 file changed, 1 insertion(+), 2 deletions(-)

diff --git a/context_test.go b/context_test.go
index 141ef81..909d272 100644
--- a/context_test.go
+++ b/context_test.go
@@ -13,7 +13,6 @@ var save bool
 
 func init() {
 	flag.BoolVar(&save, "save", false, "save PNG output for each test case")
-	flag.Parse()
 }
 
 func hash(dc *Context) string {
@@ -191,7 +190,7 @@ func TestPushPop(t *testing.T) {
 		dc.Pop()
 	}
 	saveImage(dc, "TestPushPop")
-	checkHash(t, dc, "e0d6724eb72033577811a55f7a642f6a")
+	checkHash(t, dc, "31e908ee1c2ea180da98fd5681a89d05")
 }
 
 func TestDrawStringWrapped(t *testing.T) {
-- 
2.43.0

