From e81a2f93b9605e095085e4c7e8730463e3cfa52f Mon Sep 17 00:00:00 2001
From: misaka00251 <liuxin@iscas.ac.cn>
Date: Thu, 26 Feb 2026 22:56:09 +0800
Subject: [PATCH] fix: include <ncurses.h> unconditionally

Remove platform-specific ncursesw header path and rely on <ncurses.h> across targets.

---
 gptcurses.cc | 4 ----
 1 file changed, 4 deletions(-)

diff --git a/gptcurses.cc b/gptcurses.cc
index b476700..476fc43 100644
--- a/gptcurses.cc
+++ b/gptcurses.cc
@@ -23,11 +23,7 @@
 #include <iostream>
 #include <string>
 #include <sstream>
-#if defined (__APPLE__) || (__FreeBSD__)
 #include <ncurses.h>
-#else
-#include <ncursesw/ncurses.h>
-#endif
 #include "gptcurses.h"
 #include "support.h"
 
